+/* num_samples is the maximum number of interleaved float values to write (L/R pairs).
+   Returns the number of floats written (always even). */
+uint32_t pxtnService::moo_get_scope_data( int channel, float *buffer, uint32_t num_samples ) const
+{
+	uint32_t frames;
+	uint32_t read_pos;
+	uint32_t i;
+
+	if( !buffer || !_moo_scope_enabled )
+		return 0;
+
+	if( channel < 0 || channel >= PXTONE_SCOPE_MAX_CHANNELS || channel >= _unit_num )
+		return 0;
+
+	frames = num_samples / 2;
+	if( frames > PXTONE_SCOPE_BUFFER_SIZE )
+		frames = PXTONE_SCOPE_BUFFER_SIZE;
+
+	read_pos = ( _moo_scope_write_pos[ channel ] - frames + PXTONE_SCOPE_BUFFER_SIZE )
+		& PXTONE_SCOPE_BUFFER_MASK;
+
+	for( i = 0; i < frames; i++ )
+	{
+		buffer[ i * 2     ] = _moo_scope_buffer[ channel ][ read_pos * 2     ];
+		buffer[ i * 2 + 1 ] = _moo_scope_buffer[ channel ][ read_pos * 2 + 1 ];
+		read_pos = ( read_pos + 1 ) & PXTONE_SCOPE_BUFFER_MASK;
+	}
+
+	return frames * 2;
+}
