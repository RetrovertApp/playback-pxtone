+void pxtnService::moo_enable_scope_capture( int enable )
+{
+	_moo_scope_enabled = enable;
+
+	if( enable )
+	{
+		memset( _moo_scope_buffer, 0, sizeof( _moo_scope_buffer ) );
+		memset( _moo_scope_write_pos, 0, sizeof( _moo_scope_write_pos ) );
+	}
+}
